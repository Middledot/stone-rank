{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "stone-rank",
  "version": "1.0.0",
  "identifier": "com.suncyto.stone-rank",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1213",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stone Rank",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
